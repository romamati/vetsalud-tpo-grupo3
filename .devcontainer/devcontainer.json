{
  "name": "VetSalud - Python + MongoDB + Neo4j",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/vetsalud-tpo-grupo3",
  "forwardPorts": [7474, 7687, 27017],
  "portsAttributes": {
    "7474": { "label": "Neo4j Browser" },
    "7687": { "label": "Neo4j Bolt" },
    "27017": { "label": "MongoDB" }
  },
  "postCreateCommand": "pip install -r requirements.txt && cp -n .env.codespaces .env && chmod +x scripts/load_all.sh && chmod +x ./run.sh",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  }
}
